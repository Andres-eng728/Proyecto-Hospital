<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.prohospi.ViewController.LoginViewController"
            prefWidth="400" prefHeight="300">

    <children>
        <VBox alignment="CENTER" spacing="15.0" layoutX="50.0" layoutY="40.0" prefWidth="300.0">
            <Label text="Iniciar Sesión">
                <font>
                    <Font size="20.0" />
                </font>
            </Label>

            <TextField fx:id="usuarioField" promptText="Usuario" prefWidth="200"/>
            <PasswordField fx:id="contrasenaField" promptText="Contraseña" prefWidth="200"/>
            <Button text="Ingresar" onAction="#iniciarSesion" prefWidth="200"/>
        </VBox>
    </children>
</AnchorPane>
